# Copie para .env e preencha. Nunca commite o .env real.

# Front (Vite)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key

# Auth mode: cookie (padrão, HttpOnly via BFF) | dual | legacy (rollback)
VITE_AUTH_MODE=cookie

# URL do BFF. Em produção Coolify (mesmo domínio) deixe VAZIO (= same-origin /auth/*).
# Em dev local com BFF na 8787: http://localhost:8787
VITE_AUTH_BFF_URL=

# --- Só no servidor / Coolify (runtime do BFF) ---
# SUPABASE_URL=https://SEU_PROJETO.supabase.co
# SUPABASE_ANON_KEY=sua_anon_key
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=Lax
# APP_ORIGIN=https://seu-dominio.com
# AUTH_LOGIN_MAX_ATTEMPTS=5
# AUTH_LOGIN_WINDOW_MS=900000

# --- Secrets das Edge Functions (Supabase) ---
# ALLOWED_ORIGINS=https://seu-dominio.com
# (mesmo valor do APP_ORIGIN; sem isso o CORS reflete o Origin do pedido)
